.env

# No data files are tracked (ticket 07). Postgres is the source of truth for
# Sales history (ADR 0003); everything under data/ is a generated artifact —
# raw Toast captures, the retired sales_history.parquet, forecast outputs, and
# run logs. forecast.py recreates data/ on demand, so a fresh clone needs none
# of it. The pre-migration history that migrate.py verified against still lives
# here on the machine that ran the migration; it is simply no longer committed.
/data/

__pycache__/
.venv/
*.pyc
.pytest_cache/
.ipynb_checkpoints/

# Rendered from exploration.ipynb, which already carries the same charts:
#   .venv/bin/jupyter nbconvert --to html --output-dir notebooks notebooks/exploration.ipynb
notebooks/*.html

# Claude Code worktree scratch (machine-local)
.claude/worktrees/
