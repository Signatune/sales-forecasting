# Template for the .env file at the repo root. Copy it and fill in the values:
#
#     cp .env.example .env
#
# Standard dotenv format: KEY=value, one per line, `#` comments. Every value
# reaches the code as an environment variable (see env.py) — on a laptop from
# this file, on a GitHub Actions runner from repository secrets, so the same
# code runs in both places. A real environment variable always wins over a line
# here.

# Toast API base URL, shared by both keys below.
TOAST_BASE_URL=https://ws-api.toasttab.com

# Analytics key (modifier-level reports) — toast_client.py.
TOAST_ANALYTICS_CLIENT_ID=
TOAST_ANALYTICS_CLIENT_SECRET=
TOAST_ANALYTICS_USER_ACCESS_TYPE=TOAST_MACHINE_CLIENT

# Standard key (orders:read) — toast_orders.py, and the daily capture.
TOAST_STANDARD_CLIENT_ID=
TOAST_STANDARD_CLIENT_SECRET=

# Postgres connection string. Use the Supabase session pooler, not the direct
# host — see docs/postgres.md.
DATABASE_URL=
